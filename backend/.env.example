PORT=5000
CLIENT_URL=http://localhost:5173

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=pizza_delivery_mysql

JWT_SECRET=change-this-secret-before-production
JWT_EXPIRES_IN=7d

ADMIN_EMAIL=admin@pizza.local
ADMIN_PASSWORD=Admin@12345

MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM="Pizza Delivery <no-reply@pizza.local>"
ADMIN_NOTIFICATION_EMAIL=admin@pizza.local

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_CURRENCY=INR

STOCK_CHECK_INTERVAL_MS=900000

# Keeps local development running if MySQL is not installed.
# Set to false when you want startup to fail unless MySQL is reachable.
ALLOW_DEMO_FALLBACK=true

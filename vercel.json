{
  "version": 2,
  "rewrites": [
    {
      "source": "/_/backend/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/frontend/dist/assets/$1"
    },
    {
      "source": "/((?!api|_/backend).*)",
      "destination": "/frontend/dist/$1"
    },
    {
      "source": "/((?!api|_/backend).*)",
      "destination": "/frontend/dist/index.html"
    }
  ]
}
